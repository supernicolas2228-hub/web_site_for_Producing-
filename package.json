{
  "name": "sell-is-life",
  "version": "0.1.0",
  "private": true,
  "engines": {
    "node": ">=18.17.0"
  },
  "scripts": {
    "dev": "node scripts/ensure-env.cjs && node scripts/prisma-generate.cjs && next dev -p 3030 -H 127.0.0.1",
    "dev:lan": "node scripts/ensure-env.cjs && node scripts/prisma-generate.cjs && next dev -p 3030 -H 0.0.0.0",
    "dev:public": "node scripts/dev-public.cjs",
    "dev:public:cf": "node scripts/dev-public-cf.cjs",
    "dev:phone": "powershell -ExecutionPolicy Bypass -File ./scripts/dev-phone.ps1",
    "build": "node scripts/ensure-env.cjs && node scripts/prisma-generate.cjs && next build",
    "build:beget": "node scripts/build-beget-static.cjs",
    "beget:export": "node scripts/build-beget-static.cjs",
    "beget:zip": "node scripts/build-beget-static.cjs && node scripts/zip-beget-out.cjs",
    "deploy": "npm run migrate:deploy && npm run build",
    "deploy:vps": "powershell -ExecutionPolicy Bypass -File ./scripts/deploy-vps.ps1",
    "deploy:beget": "powershell -ExecutionPolicy Bypass -File ./scripts/deploy-beget.ps1",
    "ship": "powershell -ExecutionPolicy Bypass -File ./scripts/ship.ps1",
    "pack:standalone": "powershell -ExecutionPolicy Bypass -File ./scripts/package-standalone.ps1",
    "release:vps": "powershell -ExecutionPolicy Bypass -File ./scripts/package-standalone.ps1",
    "deploy:vps:password": "python scripts/deploy-ssh-paramiko.py",
    "start": "node scripts/ensure-env.cjs && next start",
    "migrate:deploy": "node scripts/migrate-deploy.cjs",
    "postinstall": "node scripts/ensure-env.cjs && node scripts/prisma-generate.cjs"
  },
  "dependencies": {
    "@prisma/client": "^5.22.0",
    "framer-motion": "^11.11.17",
    "gsap": "^3.12.2",
    "lenis": "^1.3.21",
    "next": "14.2.18",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "recharts": "^2.13.3"
  },
  "devDependencies": {
    "@types/node": "^20",
    "@types/react": "^18",
    "@types/react-dom": "^18",
    "autoprefixer": "^10.4.21",
    "eslint": "^8",
    "eslint-config-next": "14.2.18",
    "postcss": "^8",
    "prisma": "^5.22.0",
    "tailwindcss": "^3.4.1",
    "typescript": "^5"
  }
}
