# --- Локально (по умолчанию, без Docker): SQLite ---
DATABASE_URL="file:./dev.db"

# --- На NetAngels / прод: PostgreSQL из панели (хостинг задаёт DB_CONNECTION_STRING) ---
# DATABASE_URL подставится из DB_CONNECTION_STRING автоматически, или задай вручную:
# DATABASE_URL="postgresql://USER:PASSWORD@HOST:5432/DB?schema=public"
# DB_CONNECTION_STRING="postgres://..."

# Пароль для /admin (на проде — в .env на сервере; архив деплоя .env не включает)
# Пример для своего стенда: 1234 (в проде лучше сменить на длинный секрет)
ADMIN_PASSWORD="1234"

# Публичный URL сайта (canonical / Open Graph). Локально — порт как в npm run dev (3030).
# Прод Beget + .ru (после SSL в панели): https://sanchaevkirill.ru
# Только техдомен: http://supernh5.beget.tech
# Пример NetAngels: https://sellisgood.na4u.ru
NEXT_PUBLIC_SITE_URL="http://127.0.0.1:3030"
# NEXT_PUBLIC_DEPLOY_REF — попадает в атрибут data-deploy-ref у <html> (видно «Просмотр кода» после сборки)
# NEXT_PUBLIC_GIT_SHA — опционально; в CI задаётся автоматически (data-git-sha на <html>)
# NEXT_PUBLIC_DEPLOY_REF=
# NEXT_PUBLIC_GIT_SHA=

# --- Beget (static export: npm run build:beget или npm run deploy:beget) ---
# Автовыкладка: workflow «Deploy static to Beget» при push в main — см. .github/workflows/deploy-beget-static.yml и секреты BEGET_SSH_*.
# BEGET_SSH="логин@uXXXX.freeshell.beget.tech"   или  BEGET_SSH_USER + BEGET_SSH_HOST
# Опционально: путь к приватному ключу (если не из ssh-agent). Иначе ищутся ~/.ssh/id_ed25519_beget_supernh5 и id_ed25519_beget
# BEGET_SSH_IDENTITY=C:\Users\YOU\.ssh\id_ed25519_beget_supernh5
# Список каталогов public_html на сервере (как $HOME/домен/public_html), через |, если не как по умолчанию:
# BEGET_UNPACK_PATHS=$HOME/supernh5.beget.tech/public_html|$HOME/sanchaevkirill.ru/public_html

# Соцсети и оплата (можно оставить пустым — запись через форму на сайте)
NEXT_PUBLIC_TELEGRAM_URL=
NEXT_PUBLIC_TELEGRAM_REVIEWS_URL=
NEXT_PUBLIC_PAY_OR_JOIN_URL=
NEXT_PUBLIC_PRODUCT_YOUTUBE_URL=
NEXT_PUBLIC_YOUTUBE_URL=
NEXT_PUBLIC_INSTAGRAM_URL=
NEXT_PUBLIC_VK_URL=

# Показать другу, пока ПК онлайн и открыт терминал:
# npm run dev:public      → https://….loca.lt (основной, стабильнее Cloudflare)
# npm run dev:public:cf   → https://….trycloudflare.com (часто 530 / unregistered — нестабильно)
